# Base URL for each microservice (used in Nginx proxy target; not exposed to browser)
# In development, Vite proxy forwards these from localhost ports

# WebSocket server URL (ws:// or wss:// for production)
VITE_WS_URL=ws://localhost:8080/ws

# Optional: override API base paths (rarely needed)
# VITE_AUTH_URL=http://localhost:8001
# VITE_CATALOG_URL=http://localhost:8002
# VITE_ORDER_URL=http://localhost:8003
# VITE_NOTIFICATION_URL=http://localhost:8004
