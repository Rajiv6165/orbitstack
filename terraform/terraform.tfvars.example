# Copy this file to terraform.tfvars to customize your deployment values
aws_region          = "us-east-1"
environment         = "production"
vpc_cidr            = "10.0.0.0/16"
instance_type       = "t3.medium"
ssh_key_name        = "my-aws-keypair"
allowed_ssh_cidr    = "203.0.113.25/32" # Replace with your IP address
